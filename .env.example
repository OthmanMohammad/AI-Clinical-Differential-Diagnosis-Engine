# =============================================================================
# PathoDX Environment Configuration
# Copy to .env and fill in values
# =============================================================================

# Environment: "production" | "development"
ENVIRONMENT=development

# API
API_KEY=change-me-to-a-real-secret
API_HOST=0.0.0.0
API_PORT=8000

# Neo4j AuraDB Free
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Qdrant Cloud Free
QDRANT_URL=https://xxxxxxxx.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=

# LLM Providers (free tiers)
GROQ_API_KEY=
CEREBRAS_API_KEY=

# Langfuse (free tier)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Voyage AI (free tier, production embeddings — optional)
VOYAGE_API_KEY=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10
