# ==========================================================================
# Frontend production env — reference only
#
# These values are set in the Cloudflare Pages dashboard under:
#   Workers & Pages → mooseglove-frontend → Settings → Variables and Secrets
#
# They are NOT read from this file at build time — Cloudflare injects
# them into the build environment, and Vite's `import.meta.env.VITE_*`
# picks them up. This file exists so a human can see what the prod
# Pages project expects without logging into the dashboard.
#
# IMPORTANT: every VITE_* variable is inlined into the built JS bundle
# at compile time. That means anything here is PUBLIC — visible to
# anyone who opens devtools. Do NOT put real secrets here. The API key
# is a soft gate backed by rate limiting + Cloudflare WAF, not a
# secret. If we ever need a real secret on the frontend, add a
# Cloudflare Worker in front of the API call.
# ==========================================================================

# Backend API base URL. Must be the Cloudflare Tunnel public hostname
# (NOT the VM IP — there's nothing listening on the VM publicly).
VITE_API_URL=https://api.mooseglove.com

# Soft-auth token required by the backend's X-API-Key check.
# Must match API_KEY in ~/mooseglove/.env on the VM. This token is
# NOT a secret — it's inlined into the built JS bundle and visible
# to anyone who views the page source. Its job is to give the
# backend a consistent header it can rate-limit on; real abuse
# protection comes from:
#   - Cloudflare WAF managed ruleset (blocks known attack patterns)
#   - Cloudflare edge rate limiting (per-IP, 20/min)
#   - slowapi origin rate limiting (per-IP, 10/min)
#   - CORS: only mooseglove.com can make browser-originated calls
# If you need real user-scoped auth later, do it via a Cloudflare
# Worker sitting in front of the tunnel — don't try to hide secrets
# in a Vite bundle.
VITE_API_KEY=
